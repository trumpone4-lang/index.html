<script>
    (function() {
        let donutChartInstance = null;
        
        function calculateAmortizationWithExtras(loanAmount, annualRate, years, extraMonthly) {
            const monthlyRate = annualRate / 100 / 12;
            const totalMonthsStandard = years * 12;
            let standardPayment = 0;
            if (loanAmount > 0 && monthlyRate > 0) {
                standardPayment = loanAmount * monthlyRate * Math.pow(1 + monthlyRate, totalMonthsStandard) / (Math.pow(1 + monthlyRate, totalMonthsStandard) - 1);
            } else if (loanAmount > 0 && monthlyRate === 0) {
                standardPayment = loanAmount / totalMonthsStandard;
            }
            const standardTotalInterest = (standardPayment * totalMonthsStandard) - loanAmount;
            let balance = loanAmount;
            let totalInterestWithExtras = 0;
            let monthsPaid = 0;
            const totalMonthlyWithExtra = standardPayment + extraMonthly;
            if (extraMonthly > 0 && loanAmount > 0 && monthlyRate > 0) {
                while (balance > 0.01 && monthsPaid < 600) {
                    const interestThisMonth = balance * monthlyRate;
                    let principalThisMonth = totalMonthlyWithExtra - interestThisMonth;
                    if (principalThisMonth > balance) principalThisMonth = balance;
                    totalInterestWithExtras += interestThisMonth;
                    balance -= principalThisMonth;
                    monthsPaid++;
                    if (balance <= 0) break;
                }
            } else if (extraMonthly === 0) {
                monthsPaid = totalMonthsStandard;
                totalInterestWithExtras = standardTotalInterest;
            } else if (loanAmount <= 0 || monthlyRate === 0) {
                totalInterestWithExtras = 0;
                monthsPaid = 0;
            } else {
                monthsPaid = totalMonthsStandard;
                totalInterestWithExtras = standardTotalInterest;
            }
            const payoffYears = monthsPaid / 12;
            const yearsSaved = Math.max(0, years - payoffYears);
            const interestSaved = Math.max(0, standardTotalInterest - totalInterestWithExtras);
            return { standardPayment, standardTotalInterest, totalInterestWithExtras, monthsToPayoff: monthsPaid, payoffYears, yearsSaved, interestSaved, totalMonthlyWithExtra };
        }
        
        function createMortgageCalculator() {
            const calculatorHTML = `
                <div class="mortgage-calculator-card" id="mortgageCalculatorCard">
                    <div style="text-align: center; margin-bottom: 1.5rem;">
                        <div class="tool-icon" style="font-size: 2.5rem;"></div>
                        <h3 style="font-size: 1.3rem; color: #122b44;">Mortgage Finance Calculator</h3>
                        <p style="font-size: 0.85rem; color: #6c8eaa;">Calculate total interest, monthly payments, and see how extra payments save you money</p>
                    </div>
                    <div class="calc-two-columns">
                        <div>
                            <div class="calc-input-group"><label>🏡 Home Price ($)</label><input type="number" id="homePrice" value="350000" step="10000"></div>
                            <div class="calc-input-group"><label>💵 Down Payment ($)</label><input type="number" id="downPayment" value="70000" step="5000"></div>
                            <div class="calc-input-group"><label>📅 Loan Term (years)</label><input type="number" id="loanTerm" value="30" step="1" min="1" max="40"></div>
                            <div class="calc-input-group"><label>📈 Interest Rate (%)</label><input type="number" id="interestRate" value="6.12" step="0.125"></div>
                            <div class="calc-input-group"><label>🏛️ Annual Property Tax ($)</label><input type="number" id="propertyTax" value="3850" step="500"></div>
                            <div class="calc-input-group"><label>🛡️ Annual Home Insurance ($)</label><input type="number" id="homeInsurance" value="1200" step="100"></div>
                            <div class="calc-input-group"><label>⚡ Extra Monthly Payment ($)</label><input type="number" id="extraPayment" value="0" step="50" placeholder="Additional principal payment"></div>
                            <button class="calc-button" id="calculateMortgage">⟳ Update Calculations</button>
                        </div>
                        <div>
                            <div class="donut-wrapper"><canvas id="donutChart" width="200" height="200"></canvas></div>
                            <div class="payment-breakdown">
                                <div class="breakdown-item"><span class="breakdown-label"><span class="green-dot"></span> Principal & Interest (P&I)</span><span class="breakdown-value" id="breakdownPI">$0.00</span></div>
                                <div class="breakdown-item"><span class="breakdown-label"><span class="red-dot"></span> Taxes & Insurance</span><span class="breakdown-value" id="breakdownTI">$0.00</span></div>
                                <div class="breakdown-item"><span class="breakdown-label"><strong>📋 Total Monthly Payment</strong></span><span class="breakdown-value" id="breakdownTotal"><strong>$0.00</strong></span></div>
                                <div class="breakdown-item"><span class="breakdown-label">⚡ With Extra Payment</span><span class="breakdown-value" id="monthlyWithExtra">$0.00</span></div>
                            </div>
                        </div>
                    </div>
                    <div class="extra-payment-results">
                        <h4>📊 EXTRA PAYMENT IMPACT ANALYSIS</h4>
                        <div class="extra-row"><span class="extra-label">📅 Normal payoff date:</span><span class="extra-value" id="normalPayoff">--</span></div>
                        <div class="extra-row"><span class="extra-label">🚀 New payoff date (with extras):</span><span class="extra-value saved-highlight" id="newPayoff">--</span></div>
                        <div class="extra-row"><span class="extra-label">⏱️ Years saved:</span><span class="extra-value saved-highlight" id="yearsSaved">0.0 years</span></div>
                        <div class="extra-row"><span class="extra-label">💰 Total interest normally:</span><span class="extra-value" id="normalInterest">$0</span></div>
                        <div class="extra-row"><span class="extra-label">💎 Total interest with extras:</span><span class="extra-value" id="extraInterest">$0</span></div>
                        <div class="extra-row"><span class="extra-label">🎉 TOTAL INTEREST SAVED:</span><span class="extra-value saved-highlight" id="interestSaved">$0</span></div>
                    </div>
                    <div style="margin-top: 1rem; text-align: center; font-size: 0.7rem; color: #8ba3bc;">
                        *Taxes and insurance estimates vary by location. Extra payments reduce principal directly.
                    </div>
                </div>
            `;
            document.getElementById('calculatorsGrid').innerHTML = calculatorHTML;
            
            function updateDonutChart(principalInterest, taxInsurance) {
                const ctx = document.getElementById('donutChart').getContext('2d');
                if (donutChartInstance) donutChartInstance.destroy();
                donutChartInstance = new Chart(ctx, {
                    type: 'doughnut',
                    data: { labels: ['Principal & Interest', 'Taxes & Insurance'], datasets: [{ data: [principalInterest, taxInsurance], backgroundColor: ['#10b981', '#ef4444'], borderWidth: 0, cutout: '65%' }] },
                    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, pointStyle: 'circle', font: { size: 11 }, generateLabels: (chart) => { const data = chart.data; return data.labels.map((l, i) => ({ text: `${l}: $${data.datasets[0].data[i].toFixed(2)}`, fillStyle: data.datasets[0].backgroundColor[i], index: i })); } } } } }
                });
            }
            
            function performCalculation() {
                const homePrice = parseFloat(document.getElementById('homePrice').value) || 0;
                const downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
                const loanTerm = parseFloat(document.getElementById('loanTerm').value) || 30;
                const interestRate = parseFloat(document.getElementById('interestRate').value) || 0;
                const propertyTax = parseFloat(document.getElementById('propertyTax').value) || 0;
                const homeInsurance = parseFloat(document.getElementById('homeInsurance').value) || 0;
                const extraMonthly = parseFloat(document.getElementById('extraPayment').value) || 0;
                const loanAmount = Math.max(0, homePrice - downPayment);
                const monthlyRate = interestRate / 100 / 12;
                const totalMonths = loanTerm * 12;
                let monthlyPI = 0;
                if (loanAmount > 0 && monthlyRate > 0) {
                    monthlyPI = loanAmount * monthlyRate * Math.pow(1 + monthlyRate, totalMonths) / (Math.pow(1 + monthlyRate, totalMonths) - 1);
                } else if (loanAmount > 0 && monthlyRate === 0) {
                    monthlyPI = loanAmount / totalMonths;
                }
                const monthlyTax = propertyTax / 12;
                const monthlyIns = homeInsurance / 12;
                const totalMonthly = monthlyPI + monthlyTax + monthlyIns;
                const monthlyWithExtraTotal = monthlyPI + extraMonthly + monthlyTax + monthlyIns;
                document.getElementById('breakdownPI').innerHTML = '$' + monthlyPI.toLocaleString('en-US', { minimumFractionDigits: 2 });
                document.getElementById('breakdownTI').innerHTML = '$' + (monthlyTax + monthlyIns).toLocaleString('en-US', { minimumFractionDigits: 2 });
                document.getElementById('breakdownTotal').innerHTML = '$' + totalMonthly.toLocaleString('en-US', { minimumFractionDigits: 2 });
                document.getElementById('monthlyWithExtra').innerHTML = '$' + monthlyWithExtraTotal.toLocaleString('en-US', { minimumFractionDigits: 2 });
                updateDonutChart(monthlyPI, monthlyTax + monthlyIns);
                if (loanAmount > 0 && interestRate > 0) {
                    const results = calculateAmortizationWithExtras(loanAmount, interestRate, loanTerm, extraMonthly);
                    const normalDate = new Date(); normalDate.setFullYear(normalDate.getFullYear() + loanTerm);
                    const newDate = new Date(); newDate.setFullYear(newDate.getFullYear() + results.payoffYears);
                    document.getElementById('normalPayoff').innerHTML = `${loanTerm} years (${normalDate.toLocaleDateString()})`;
                    document.getElementById('newPayoff').innerHTML = `${results.payoffYears.toFixed(1)} years (${newDate.toLocaleDateString()})`;
                    document.getElementById('yearsSaved').innerHTML = `${results.yearsSaved.toFixed(1)} years`;
                    document.getElementById('normalInterest').innerHTML = '$' + results.standardTotalInterest.toLocaleString('en-US', { minimumFractionDigits: 0 });
                    document.getElementById('extraInterest').innerHTML = '$' + results.totalInterestWithExtras.toLocaleString('en-US', { minimumFractionDigits: 0 });
                    document.getElementById('interestSaved').innerHTML = '$' + results.interestSaved.toLocaleString('en-US', { minimumFractionDigits: 0 });
                } else {
                    document.getElementById('normalPayoff').innerHTML = `${loanTerm} years`; document.getElementById('newPayoff').innerHTML = `${loanTerm} years`; document.getElementById('yearsSaved').innerHTML = '0.0 years';
                    document.getElementById('normalInterest').innerHTML = '$0'; document.getElementById('extraInterest').innerHTML = '$0'; document.getElementById('interestSaved').innerHTML = '$0';
                }
            }
            document.getElementById('calculateMortgage').addEventListener('click', performCalculation);
            ['homePrice', 'downPayment', 'loanTerm', 'interestRate', 'propertyTax', 'homeInsurance', 'extraPayment'].forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener('input', performCalculation); });
            performCalculation();
        }
        
        createMortgageCalculator();
        
        const drawerToolsList = document.getElementById('drawerToolsList');
        const allTools = [ "🏠 Mortgage Calculator", "📈 Investment Calculator", "💰 Savings Calculator", "📊 Retirement Planner", "🏦 Loan Comparison Tool", "📉 Amortization Schedule", "🔄 Refinance Breakeven", "💳 Credit Card Payoff", "📅 DTI Calculator", "🏡 Rent vs Buy Analyzer", "📈 Compound Interest Calculator", "🎓 Student Loan Planner" ];
        allTools.forEach(toolName => { const toolLink = document.createElement('a'); toolLink.className = 'drawer-item'; toolLink.innerHTML = toolName; toolLink.href = '#'; toolLink.style.fontSize = '0.85rem'; toolLink.addEventListener('click', (e) => { e.preventDefault(); document.getElementById('mortgageCalculatorCard').scrollIntoView({ behavior: 'smooth' }); closeDrawer(); }); drawerToolsList.appendChild(toolLink); });
        
        const modal = document.getElementById('infoModal'); const modalTitle = document.getElementById('modalTitle'); const modalText = document.getElementById('modalText'); const closeModalBtn = document.getElementById('closeModalBtn');
        function closeModalFunc() { modal.style.display = 'none'; }
        closeModalBtn.addEventListener('click', closeModalFunc); window.addEventListener('click', (e) => { if (e.target === modal) closeModalFunc(); });
        const contentMap = { about: { title: "📌 About SmartRatesLab", body: "<p>SmartRatesLab delivers professional-grade financial calculators. Founded in 2022, we're committed to transparency and accuracy.</p>" }, contact: { title: "📧 Contact Us", body: "<p><strong>Email:</strong> supportentry1@gmail.com<br>Hours: Mon-Fri 9am-6pm EST</p>" }, privacy: { title: "🔒 Privacy Policy", body: "<p>We do not store personal financial data. Calculations happen locally in your browser.</p>" }, terms: { title: "⚖️ Terms of Service", body: "<p>Calculators are for educational purposes only. Not financial advice.</p>" }, home: { title: "SmartRatesLab", body: "<p>Welcome to SmartRatesLab — your hub for mortgage finance calculators.</p>" } };
        function openModal(type) { const data = contentMap[type]; if (data) { modalTitle.innerText = data.title; modalText.innerHTML = data.body; modal.style.display = 'flex'; } }
        function handleNavigation(navType) { if (navType === 'home') { window.scrollTo({ top: 0, behavior: 'smooth' }); openModal('home'); } else { openModal(navType); } closeDrawer(); }
        const drawer = document.getElementById('drawerMenu'); const overlay = document.getElementById('drawerOverlay'); const menuBtn = document.getElementById('menuButton'); const closeDrawerBtn = document.getElementById('closeDrawerBtn');
        function openDrawer() { drawer.classList.add('open'); overlay.classList.add('active'); document.body.style.overflow = 'hidden'; }
        function closeDrawer() { drawer.classList.remove('open'); overlay.classList.remove('active'); document.body.style.overflow = ''; }
        menuBtn.addEventListener('click', openDrawer); closeDrawerBtn.addEventListener('click', closeDrawer); overlay.addEventListener('click', closeDrawer);
        document.querySelectorAll('.drawer-item[data-nav]').forEach(item => { item.addEventListener('click', (e) => { e.preventDefault(); handleNavigation(item.getAttribute('data-nav')); }); });
        document.querySelectorAll('.footer-nav-link, .footer-legal-link, [data-nav]').forEach(link => { if (!link.closest('.drawer')) { link.addEventListener('click', (e) => { e.preventDefault(); const nav = link.getAttribute('data-nav'); if (nav) handleNavigation(nav); }); } });
        document.getElementById('homeLinkHeader')?.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); openModal('home'); });
        const blogPosts = { 1: { title: "Mortgage prepayment vs. index funds", content: "<p>Extra mortgage payments give a guaranteed return equal to your interest rate.</p>" }, 2: { title: "Real return after inflation & taxes", content: "<p>Adjust nominal returns for inflation and taxes.</p>" }, 3: { title: "Coast FIRE fundamentals", content: "<p>Coast FIRE is when your existing investments will grow to cover retirement.</p>" }, 4: { title: "Mortgage recasting explained", content: "<p>Recasting lowers monthly payments without refinancing.</p>" }, 5: { title: "Tax-loss harvesting strategies", content: "<p>Offset capital gains by selling losing positions.</p>" } };
        document.querySelectorAll('.blog-item').forEach(item => { item.addEventListener('click', () => { const blogId = item.getAttribute('data-blog'); const post = blogPosts[blogId]; if (post) { modalTitle.innerText = post.title; modalText.innerHTML = post.content; modal.style.display = 'flex'; } closeDrawer(); }); });
        
        document.querySelectorAll('.faq-question').forEach(q => { q.addEventListener('click', () => { const answer = q.parentElement.querySelector('.faq-answer'); answer.classList.toggle('show'); q.querySelector('.toggle-icon').innerText = answer.classList.contains('show') ? '−' : '+'; }); });
    })();
</script>
    
